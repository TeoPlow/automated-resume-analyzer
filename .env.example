# Подключение PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=resume_analyzer
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password

# Подключение Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Подключение RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Подключение MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# Profile Настройки
RESUME_MAX_FILE_SIZE_BYTES=10485760
AWS_REGION=us-east-1
RESUME_BUCKET=resumes

# Api Настройки
JWT_SECRET=dev-jwt-secret-change-me
JWT_ISSUER=resume-analyzer-api
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=1209600
AUTH_STORE_BACKEND=redis
AUTH_REDIS_PREFIX=auth

# Gateway proxy routing
PROFILE_SERVICE_URL=http://profile:8000
VACANCY_SERVICE_URL=http://vacancy:8000
MATCHING_SERVICE_URL=http://matching:8000
SEARCH_SERVICE_URL=http://search:8000
GATEWAY_PROXY_TIMEOUT_SECONDS=15

# Gateway rate limiting
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Internal service auth
GATEWAY_INTERNAL_TOKEN=dev-internal-token-change-me

# Demo users for gateway auth
ADMIN_PASSWORD=admin123
HR_PASSWORD=hr123