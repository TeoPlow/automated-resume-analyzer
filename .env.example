# === База данных (PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://app_user:app_password@postgres:5432/resume_analyzer
DB_ECHO=false

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === RabbitMQ ===
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
EXCHANGE_NAME=ara.events
DLX_NAME=ara.events.dlx

# === MinIO (S3-совместимое хранилище) ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=resumes-raw
MINIO_USE_SSL=false

# === Ollama (LLM) ===
OLLAMA_URL=http://ollama:11434
LLM_MODEL=qwen2.5:7b
LLM_MAX_RETRIES=2

# === JWT / Аутентификация ===
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=86400

# === Rate Limiting ===
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=60

# === Демо-пользователи (Gateway) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
HR_USERNAME=hr
HR_PASSWORD=hr123

# === Inter-service токен ===
INTERNAL_TOKEN=internal-secret-token

# === Proxy-маршрутизация (Gateway) ===
PROFILE_SERVICE_URL=http://profile:8000
VACANCY_SERVICE_URL=http://vacancy:8000
MATCHING_SERVICE_URL=http://matching:8000
SEARCH_SERVICE_URL=http://search:8000

# === Matching (веса скоринга) ===
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
DEFAULT_WEIGHT_SKILLS=0.40
DEFAULT_WEIGHT_EXPERIENCE=0.25
DEFAULT_WEIGHT_GRADE=0.15
DEFAULT_WEIGHT_LOCATION=0.10
DEFAULT_WEIGHT_SALARY=0.10

# === Загрузка файлов (Profile) ===
MAX_FILE_SIZE=10485760

# === Поиск (Search) ===
DEFAULT_LIMIT=20
MAX_LIMIT=100

# === Логирование ===
LOG_LEVEL=INFO

# === Инфраструктура (docker-compose) ===
POSTGRES_DB=resume_analyzer
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123